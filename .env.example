# ─────────────────────────────────────────────────────────────────────────────
# .env.example  —  copy this to .env and fill in your keys
# .env is gitignored and will never be committed
# ─────────────────────────────────────────────────────────────────────────────

# ── Binance TESTNET keys ──────────────────────────────────────────────────────
# Get these from: https://testnet.binance.vision/
# These are FAKE keys for paper trading only — no real money involved
TESTNET_API_KEY=paste_your_testnet_api_key_here
TESTNET_SECRET=paste_your_testnet_secret_here

# ── Binance LIVE keys (only needed for real trading) ─────────────────────────
# Get these from: https://www.binance.com/en/my/settings/api-management
# Enable: Reading + Spot & Margin Trading  (do NOT enable Withdrawals)
# Whitelist your IP address for extra security
LIVE_API_KEY=paste_your_live_api_key_here
LIVE_SECRET=paste_your_live_secret_here

# ── Live trading confirmation ──────────────────────────────────────────────────
# Uncomment and set to YES only when you are ready to trade with real money.
# Required when running with --live flag.
# CONFIRM_LIVE_TRADING=YES

# ── DeepSeek LLM API key ──────────────────────────────────────────────────────
# Used by the LLM trader brain for market decisions.
# Get one from: https://platform.deepseek.com/
# DEEPSEEK_API_KEY=paste_your_deepseek_api_key_here

# ── Daily report email (daily_report.py) ─────────────────────────────────────
# Sends the daily status digest to your own inbox via Gmail SMTP.
# App password: Google Account → Security → 2-Step Verification → App passwords
# (16 characters, spaces optional). Revocable anytime; SMTP-use only.
# GMAIL_ADDRESS=you@gmail.com
# GMAIL_APP_PASSWORD=paste_your_16_char_app_password_here